---
import { SITE_TITLE } from '@/consts';
const year = new Date().getFullYear();
---

<footer class="border-t border-gray-200 bg-white">
  <div
    class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-2 px-4 py-6 text-sm text-gray-500 sm:flex-row"
  >
    <p>&copy; {year} {SITE_TITLE}. All rights reserved.</p>
    <a href="/rss.xml" class="hover:text-gray-900">RSS</a>
  </div>
</footer>
