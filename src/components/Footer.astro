---
import { SITE_TITLE } from '@/consts';
import { Twitter, Github, Linkedin, Mail, Rss, ArrowUpRight } from 'lucide-react';

const year = new Date().getFullYear();
const pathname = Astro.url.pathname;
const isBlog = pathname === '/blog' || pathname.startsWith('/blog/');

const productLinks = [
  { label: 'Features', href: '/#features' },
  { label: 'How It Works', href: '/#how-it-works' },
  { label: 'Use Cases', href: '/#use-cases' },
  { label: 'Pricing', href: '/#pricing' },
];

const resourceLinks = [
  { label: 'Blog', href: '/blog' },
  { label: 'FAQ', href: '/#faq' },
  { label: 'Documentation', href: '/docs' },
  { label: 'API Reference', href: '/docs/api' },
];

const companyLinks = [
  { label: 'About', href: '/about' },
  { label: 'Contact', href: 'mailto:hello@pandaqr.xyz' },
  { label: 'Privacy', href: '/privacy' },
  { label: 'Terms', href: '/terms' },
];

const socialLinks = [
  { icon: Twitter, href: 'https://twitter.com/pandaqr', label: 'Twitter' },
  { icon: Github, href: 'https://github.com/pandaqr', label: 'GitHub' },
  { icon: Linkedin, href: 'https://linkedin.com/company/pandaqr', label: 'LinkedIn' },
  { icon: Mail, href: 'mailto:hello@pandaqr.xyz', label: 'Email' },
];
---

<footer class="relative overflow-hidden bg-gray-950 text-gray-400">
  {/* Subtle top border with gradient */}
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-white/15 to-transparent"></div>

  {/* Ambient glow */}
  <div class="absolute -top-40 left-1/2 -translate-x-1/2 w-[700px] h-[300px] bg-brand-600 rounded-full blur-[140px] opacity-[0.08] pointer-events-none"></div>

  <div class="container mx-auto px-6 max-w-7xl relative z-10">
    {/* Main footer grid */}
    <div class="grid grid-cols-2 lg:grid-cols-12 gap-y-12 gap-x-8 py-20">
      {/* Brand column */}
      <div class="col-span-2 lg:col-span-4 max-w-sm">
        <a href="/" class="inline-flex items-center gap-2 text-xl font-bold tracking-tight text-white">
          <img
            src="/images/logo.png"
            alt="PandaQR Logo"
            class="w-9 h-9 rounded-[10px]"
            onerror="this.src='data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHZpZXdCb3g9IjAgMCAxMDAgMTAwIj48cmVjdCB3aWR0aD0iMTAwIiBoZWlnaHQ9IjEwMCIgZmlsbD0iIzNCODJGNiIgcng9IjIwIi8+PGNpcmNsZSBjeD0iNTAiIGN5PSI1MCIgcj0iMjAiIGZpbGw9IndoaXRlIi8+PC9zdmc+'"
          />
          <span>PandaQR</span>
        </a>
        <p class="mt-5 text-sm leading-relaxed text-gray-400">
          One QR code, forever yours. Change the destination anytime — the code stays the same. Perfect for menus, posters, and social links.
        </p>

        {/* Newsletter */}
        <form class="mt-8" onsubmit="event.preventDefault();">
          <label for="newsletter-email" class="text-xs font-semibold tracking-wider uppercase text-gray-300">
            Stay in the loop
          </label>
          <div class="mt-3 flex gap-2 p-1 rounded-full bg-white/5 border border-white/10 backdrop-blur-md focus-within:border-white/25 transition-colors">
            <input
              id="newsletter-email"
              type="email"
              required
              placeholder="you@email.com"
              class="flex-1 bg-transparent px-4 py-2 text-sm text-white placeholder:text-gray-500 focus:outline-none"
            />
            <button
              type="submit"
              class="inline-flex items-center justify-center w-9 h-9 rounded-full bg-white text-gray-900 hover:bg-gray-100 transition-colors"
              aria-label="Subscribe"
            >
              <ArrowUpRight className="w-4 h-4" />
            </button>
          </div>
        </form>
      </div>

      {/* Link columns */}
      <div class="col-span-1 lg:col-span-2 lg:col-start-6">
        <h3 class="text-xs font-semibold tracking-wider uppercase text-white">Product</h3>
        <ul class="mt-5 space-y-3 text-sm">
          {productLinks.map((link) => (
            <li>
              <a href={link.href} class="text-gray-400 hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="col-span-1 lg:col-span-2">
        <h3 class="text-xs font-semibold tracking-wider uppercase text-white">Resources</h3>
        <ul class="mt-5 space-y-3 text-sm">
          {resourceLinks.map((link) => (
            <li>
              <a href={link.href} class="text-gray-400 hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="col-span-2 lg:col-span-2">
        <h3 class="text-xs font-semibold tracking-wider uppercase text-white">Company</h3>
        <ul class="mt-5 space-y-3 text-sm">
          {companyLinks.map((link) => (
            <li>
              <a href={link.href} class="text-gray-400 hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    {/* Bottom bar */}
    <div class="border-t border-white/10 py-7 flex flex-col-reverse sm:flex-row items-center justify-between gap-5 text-xs text-gray-500">
      <p>&copy; {year} {SITE_TITLE}. All rights reserved.</p>

      <div class="flex items-center gap-2">
        {socialLinks.map((social) => (
          <a
            href={social.href}
            aria-label={social.label}
            target="_blank"
            rel="noreferrer"
            class="inline-flex items-center justify-center w-9 h-9 rounded-full bg-white/5 hover:bg-white/10 border border-white/10 hover:border-white/20 text-gray-300 hover:text-white transition-colors"
          >
            <social.icon className="w-4 h-4" />
          </a>
        ))}
        {isBlog && (
          <a
            href="/rss.xml"
            aria-label="RSS feed"
            class="inline-flex items-center justify-center w-9 h-9 rounded-full bg-white/5 hover:bg-white/10 border border-white/10 hover:border-white/20 text-gray-300 hover:text-white transition-colors"
          >
            <Rss className="w-4 h-4" />
          </a>
        )}
      </div>
    </div>
  </div>
</footer>
