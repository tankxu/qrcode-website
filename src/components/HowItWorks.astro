---
import { MousePointerClick, Printer, RotateCw } from 'lucide-react';

const steps = [
  {
    title: '1. Create & Target',
    description: 'Generate your permanent QR code and set its initial destination—a link, an image, or a multi-link page.',
    icon: MousePointerClick,
    delay: '0.2s'
  },
  {
    title: '2. Print Everywhere',
    description: 'Put your QR code on posters, menus, business cards, and packaging. It will never expire or break.',
    icon: Printer,
    delay: '0.4s'
  },
  {
    title: '3. Update Anytime',
    description: 'Log in to the dashboard and change the destination. The printed QR codes instantly route to the new content.',
    icon: RotateCw,
    delay: '0.6s'
  }
];
---

<section class="py-32 bg-gray-50 relative overflow-hidden">
  {/* Decorative background element */}
  <div class="absolute top-0 right-0 w-[800px] h-[800px] bg-brand-50 rounded-full blur-[100px] opacity-50 -translate-y-1/2 translate-x-1/3"></div>

  <div class="container mx-auto px-6 relative z-10 max-w-5xl">
    <div class="text-center mb-20 opacity-0" style="animation: fade-in-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;">
      <h2 class="text-4xl md:text-5xl font-bold tracking-tight mb-6">How PandaQR works</h2>
      <p class="text-xl text-gray-500 font-light max-w-2xl mx-auto">
        A seamless workflow designed to separate your physical print from your digital content.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-12 relative">
      {/* Connecting line for desktop */}
      <div class="hidden md:block absolute top-12 left-1/6 right-1/6 h-0.5 bg-gradient-to-r from-gray-200 via-brand-200 to-gray-200 z-0"></div>

      {steps.map((step, i) => (
        <div 
          class="relative z-10 flex flex-col items-center text-center group opacity-0"
          style={`animation: fade-in-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards ${step.delay};`}
        >
          <div class="w-24 h-24 bg-white rounded-3xl shadow-xl border border-gray-100 flex items-center justify-center mb-8 group-hover:-translate-y-2 transition-transform duration-500 relative">
            <div class="absolute inset-0 bg-brand-500 opacity-0 group-hover:opacity-5 rounded-3xl transition-opacity duration-500"></div>
            <step.icon className="w-10 h-10 text-brand-600" />
          </div>
          <h3 class="text-2xl font-bold mb-4">{step.title}</h3>
          <p class="text-gray-500 leading-relaxed font-medium">
            {step.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
