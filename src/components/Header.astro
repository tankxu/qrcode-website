---
import { SITE_TITLE, NAV_LINKS } from '@/consts';

const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href);
---

<header class="border-b border-gray-200 bg-white">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4">
    <a href="/" class="flex items-center gap-2 text-xl font-bold tracking-tight text-gray-900">
      <img src="/images/logo.png" alt="PandaQR Logo" class="w-8 h-8 rounded-[8px]" onerror="this.src='data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHZpZXdCb3g9IjAgMCAxMDAgMTAwIj48cmVjdCB3aWR0aD0iMTAwIiBoZWlnaHQ9IjEwMCIgZmlsbD0iIzNCODJGNiIgcng9IjIwIi8+PGNpcmNsZSBjeD0iNTAiIGN5PSI1MCIgcj0iMjAiIGZpbGw9IndoaXRlIi8+PC9zdmc+'" />
      PandaQR
    </a>
    <ul class="flex items-center gap-6 text-sm font-medium">
      {
        NAV_LINKS.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={[
                'transition-colors hover:text-gray-900',
                isActive(link.href) ? 'text-gray-900' : 'text-gray-500',
              ]}
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>
