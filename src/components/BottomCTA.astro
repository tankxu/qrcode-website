---
import { ArrowRight } from 'lucide-react';
---

<section class="py-32 relative overflow-hidden bg-gray-900 text-white">
  {/* Abstract grid pattern for dark mode */}
  <div class="absolute inset-0 opacity-10" style="background-image: linear-gradient(to right, rgba(255,255,255,0.1) 1px, transparent 1px), linear-gradient(to bottom, rgba(255,255,255,0.1) 1px, transparent 1px); background-size: 40px 40px;"></div>
  
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-brand-500 rounded-full blur-[150px] opacity-20"></div>

  <div class="container mx-auto px-6 relative z-10 text-center max-w-3xl">
    <h2 class="text-5xl md:text-6xl font-extrabold tracking-tight mb-8">
      Ready to make your codes permanent?
    </h2>
    <p class="text-xl text-gray-400 font-light mb-12">
      Join thousands of modern creators, businesses, and communities who never have to reprint a QR code again.
    </p>
    
    <a
      href="https://app.pandaqr.xyz"
      class="group relative inline-flex items-center justify-center gap-2 px-10 py-5 text-lg font-semibold text-gray-900 bg-white rounded-full overflow-hidden transition-transform hover:scale-105 active:scale-95 shadow-2xl shadow-white/10"
    >
      <span class="absolute inset-0 w-full h-full bg-gradient-to-r from-gray-100 to-white opacity-0 group-hover:opacity-100 transition-opacity duration-500 ease-out"></span>
      <span class="relative flex items-center gap-2">
        Get Started for Free
        <ArrowRight className="w-5 h-5 group-hover:translate-x-1 transition-transform" />
      </span>
    </a>
  </div>
</section>
