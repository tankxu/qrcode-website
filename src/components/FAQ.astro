---
const faqs = [
  {
    question: "Do PandaQR codes really never expire?",
    answer: "Yes. Once you generate a PandaQR code, the pattern is permanently yours. As long as your account is active, the QR code will continue to route traffic to whatever destination you set."
  },
  {
    question: "Can I change the destination after printing?",
    answer: "Absolutely. That's the core feature of PandaQR. You can print the code on 10,000 posters, and later change the destination link or image from your dashboard in seconds."
  },
  {
    question: "What types of content can I link to?",
    answer: "Currently, you can link to any external URL (like your website or social media), upload an image directly (great for menus or promos), or create a custom multi-link page."
  },
  {
    question: "Do users need to install an app to scan?",
    answer: "No. PandaQR codes work natively with any standard smartphone camera (iOS or Android) and apps like WeChat or WhatsApp."
  },
  {
    question: "Can I track how many people scan my codes?",
    answer: "Yes, every PandaQR comes with real-time analytics. You can track total scans, unique visitors, and see the scanning trends over time from your dashboard."
  }
];
---

<section class="py-32 bg-white">
  <div class="container mx-auto px-6 max-w-3xl">
    <div class="text-center mb-16 opacity-0" style="animation: fade-in-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;">
      <h2 class="text-4xl md:text-5xl font-bold tracking-tight mb-4">Frequently Asked Questions</h2>
      <p class="text-lg text-gray-500">Everything you need to know about the product and billing.</p>
    </div>

    <div class="space-y-6">
      {faqs.map((faq, i) => (
        <div 
          class="glass-panel p-8 rounded-3xl opacity-0"
          style={`animation: fade-in-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards ${i * 0.1 + 0.2}s;`}
        >
          <h3 class="text-xl font-bold text-gray-900 mb-3">{faq.question}</h3>
          <p class="text-gray-600 leading-relaxed">{faq.answer}</p>
        </div>
      ))}
    </div>
  </div>
</section>
