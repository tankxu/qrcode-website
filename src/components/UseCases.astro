---
import { Building2, Store, Ticket, Briefcase } from 'lucide-react';

const cases = [
  {
    title: 'Offline Retail & Dining',
    description: 'Update seasonal menus, daily specials, and promotional campaigns without re-printing table tents.',
    icon: Store,
    tags: ['Menus', 'Promos', 'Wi-Fi']
  },
  {
    title: 'Events & Conferences',
    description: 'Change the schedule, speaker bios, and venue maps on the fly. Attendees always scan the latest version.',
    icon: Ticket,
    tags: ['Schedules', 'Maps', 'Feedback']
  },
  {
    title: 'Agencies & Creators',
    description: 'A single QR code on your business card that routes to your latest portfolio, Linktree, or social campaign.',
    icon: Briefcase,
    tags: ['Portfolios', 'Socials', 'Vcards']
  },
  {
    title: 'Real Estate & Properties',
    description: 'Place a code on a "For Sale" sign. When sold, redirect it to your agency\'s main listings page.',
    icon: Building2,
    tags: ['Listings', 'Virtual Tours', 'Agents']
  }
];
---

<section class="py-32 bg-white relative">
  {/* Dynamic floating shapes */}
  <div class="absolute top-1/4 left-10 w-4 h-4 rounded-full bg-brand-400 opacity-50 animate-float" style="animation-delay: 0s;"></div>
  <div class="absolute top-1/3 right-20 w-3 h-3 rounded-full bg-blue-400 opacity-50 animate-float" style="animation-delay: 1.5s;"></div>
  <div class="absolute bottom-1/4 left-1/4 w-5 h-5 rounded-full bg-orange-400 opacity-30 animate-float" style="animation-delay: 3s;"></div>

  <div class="container mx-auto px-6 max-w-6xl relative z-10">
    <div class="flex flex-col md:flex-row gap-12 items-end mb-16 opacity-0" style="animation: fade-in-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;">
      <div class="flex-1">
        <h2 class="text-4xl md:text-5xl font-bold tracking-tight mb-6">Designed for every scenario.</h2>
        <p class="text-xl text-gray-500 font-light max-w-xl">
          From independent creators to global enterprises, PandaQR adapts to any physical-to-digital workflow.
        </p>
      </div>
      <div class="hidden md:flex gap-4">
        <button class="w-12 h-12 rounded-full border border-gray-200 flex items-center justify-center hover:bg-gray-50 transition-colors">
          <svg class="w-5 h-5 text-gray-600 rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
        </button>
        <button class="w-12 h-12 rounded-full bg-gray-900 text-white flex items-center justify-center hover:bg-gray-800 transition-colors shadow-lg">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
        </button>
      </div>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
      {cases.map((item, i) => (
        <div 
          class="group bg-gray-50 rounded-3xl p-8 border border-gray-100 hover:bg-white hover:shadow-xl hover:shadow-gray-200/50 hover:border-brand-200 transition-all duration-500 opacity-0"
          style={`animation: fade-in-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards ${i * 0.1 + 0.2}s;`}
        >
          <div class="w-14 h-14 bg-white rounded-2xl shadow-sm border border-gray-100 flex items-center justify-center mb-6 group-hover:scale-110 group-hover:text-brand-600 transition-all duration-500">
            <item.icon className="w-7 h-7 text-gray-700 group-hover:text-brand-600 transition-colors" />
          </div>
          <h3 class="text-xl font-bold mb-3 group-hover:text-brand-600 transition-colors">{item.title}</h3>
          <p class="text-gray-500 text-sm leading-relaxed mb-6">
            {item.description}
          </p>
          <div class="flex flex-wrap gap-2">
            {item.tags.map(tag => (
              <span class="px-3 py-1 bg-white border border-gray-200 rounded-full text-xs font-medium text-gray-600 group-hover:border-brand-200 transition-colors">
                {tag}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
