---
import { Quote } from 'lucide-react';

const testimonials = [
  {
    quote: "We used to throw away hundreds of table tents every season when our menu changed. Now, we print the PandaQR code once, and I just upload the new PDF from my phone. It's a lifesaver.",
    author: "Sarah Jenkins",
    role: "Owner, The Daily Roast Cafe",
    initials: "SJ",
    color: "bg-orange-100 text-orange-700"
  },
  {
    quote: "As a community manager, my WeChat group QR codes expiring every 7 days was a nightmare. PandaQR solved this completely. One permanent link, endless groups.",
    author: "David Chen",
    role: "Web3 Community Lead",
    initials: "DC",
    color: "bg-green-100 text-green-700"
  },
  {
    quote: "I put my PandaQR on the back of my phone case. When I'm at networking events, people scan it and get routed to a custom landing page that I update based on the event I'm at.",
    author: "Elena Rodriguez",
    role: "Freelance Designer",
    initials: "ER",
    color: "bg-blue-100 text-blue-700"
  }
];
---

<section class="py-32 bg-gray-50 relative overflow-hidden">
  <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-gray-200 to-transparent"></div>

  <div class="container mx-auto px-6 max-w-6xl relative z-10">
    <div class="text-center mb-20 opacity-0" style="animation: fade-in-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;">
      <h2 class="text-4xl md:text-5xl font-bold tracking-tight mb-6">Loved by creators and businesses.</h2>
      <p class="text-xl text-gray-500 font-light max-w-2xl mx-auto">
        See how people are using permanent QR codes to streamline their operations and marketing.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      {testimonials.map((t, i) => (
        <div 
          class="bg-white rounded-3xl p-8 shadow-sm border border-gray-100 hover:shadow-xl transition-shadow duration-500 relative group opacity-0"
          style={`animation: fade-in-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards ${i * 0.15 + 0.2}s;`}
        >
          <Quote className="w-10 h-10 text-gray-100 absolute top-8 right-8 group-hover:text-brand-50 transition-colors" />
          
          <p class="text-gray-600 text-lg leading-relaxed mb-8 relative z-10 font-medium">
            "{t.quote}"
          </p>
          
          <div class="flex items-center gap-4 mt-auto">
            <div class={`w-12 h-12 rounded-full ${t.color} flex items-center justify-center font-bold text-lg`}>
              {t.initials}
            </div>
            <div>
              <div class="font-bold text-gray-900">{t.author}</div>
              <div class="text-sm text-gray-500">{t.role}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
